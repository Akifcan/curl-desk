{
  "name": "curl-desk",
  "displayName": "Curl Desk",
  "description": "Postman-like API testing tool inside VS Code",
  "version": "0.1.0",
  "publisher": "AkifcanKara",
  "icon": "logo-black.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akifcan/curl-desk"
  },
  "license": "MIT",
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "http",
    "rest",
    "api",
    "postman",
    "request",
    "client"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "curl-desk.open",
        "title": "Curl Desk: Open"
      },
      {
        "command": "curl-desk.sendSelection",
        "title": "Curl Desk: Use as Request Body"
      }
    ],
    "keybindings": [
      {
        "command": "curl-desk.open",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "curl-desk-sidebar",
          "title": "Curl Desk",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "curl-desk-sidebar": [
        {
          "type": "webview",
          "id": "curl-desk.sidebar",
          "name": "Curl Desk"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "curl-desk.open"
        },
        {
          "command": "curl-desk.sendSelection",
          "when": "editorHasSelection"
        }
      ],
      "editor/context": [
        {
          "command": "curl-desk.sendSelection",
          "when": "editorHasSelection",
          "group": "curl-desk@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "build:webview": "cd webview-ui && npm run build",
    "build": "npm run build:webview && npm run compile",
    "watch:ext": "node esbuild.js --watch",
    "watch:ui": "cd webview-ui && npm run dev",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}